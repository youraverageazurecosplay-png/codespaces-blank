{
  "name": "nova-side-panel",
  "displayName": "Nova Side Panel",
  "description": "Open Nova AI in a VS Code side panel for repository-aware coding assistance.",
  "version": "0.1.0",
  "publisher": "nova",
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "nova.openSidePanel",
        "title": "Nova: Open Side Panel",
        "icon": "$(wand)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nova-explorer",
          "title": "Nova",
          "icon": "$(wand)"
        }
      ]
    },
    "views": {
      "nova-explorer": [
        {
          "id": "novaExplorer",
          "name": "Nova AI Assistant"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "nova.openSidePanel",
          "group": "navigation",
          "when": "resourceScheme == file"
        }
      ],
      "view/title": [
        {
          "command": "nova.openSidePanel",
          "group": "navigation",
          "view": "novaExplorer"
        }
      ]
    },
    "keybindings": [
      {
        "command": "nova.openSidePanel",
        "key": "ctrl+alt+n",
        "mac": "cmd+alt+n"
      }
    ]
  }
}
